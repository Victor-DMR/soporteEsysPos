# Leave VITE_API_BASE_URL empty in local dev to call /api through the Vite proxy.
# Change API_PROXY_TARGET only if php artisan serve is not running on 127.0.0.1:8000.
# Use /api when frontend and backend share the same production domain.
# Use https://www.soporte.com/api when the backend is on another domain.
VITE_PUBLIC_BASE_PATH=/
VITE_API_BASE_URL=
API_PROXY_TARGET=http://127.0.0.1:8000
VITE_PUSHER_APP_KEY=
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https
VITE_PUSHER_APP_CLUSTER=mt1
